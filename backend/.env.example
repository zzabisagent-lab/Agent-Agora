NODE_ENV=development
PORT=5000
API_BASE_PATH=/api/v1
MONGO_URI=mongodb://localhost:27017/agentagora
FRONTEND_URL=http://localhost:3000
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=agora_access
CSRF_COOKIE_NAME=agora_csrf
BCRYPT_SALT_ROUNDS=12
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AgentAgora <noreply@example.com>
# Bootstrap admin account created on first startup.
# Defaults: admin@localhost / admin
# Set ADMIN_BOOTSTRAP_ENABLED=false to disable auto-creation.
ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=admin
INVITATION_EXPIRES_DAYS=7
AGENT_API_KEY_PREFIX=agora_
LOG_LEVEL=debug
RATE_LIMIT_MODE=memory
